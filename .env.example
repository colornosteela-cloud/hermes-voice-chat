# ============================================================
# Hermes Voice Chat + Teela Robotics Environment Configuration
# Copy this file to .env and fill in your actual API keys
# ============================================================

# ── Hume AI (Voice Chat TTS) ──────────────────────────────
# Get your API key at: https://app.hume.ai/keys
HUME_API_KEY=your_hume_api_key_here
HUME_VOICE_ID=your_hume_voice_id_here

# ── Ollama (Local LLM) ───────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=kimi-k2.6:cloud
OLLAMA_API_KEY=your_ollama_key_here

# ── Whisper (Local STT) ──────────────────────────────────
# Model: tiny, base, small, medium, large
WHISPER_MODEL=base

# ── Voice Chat Server ────────────────────────────────────
# Port for the FastAPI web server
VOICE_PORT=8765

# ── Teela Robotics (ZeroMQ Bus) ──────────────────────────
# ZMQ pub/sub endpoints for the robotics subsystem
TEELA_ZMQ_PUB=tcp://127.0.0.1:5555
TEELA_ZMQ_SUB=tcp://127.0.0.1:5556

# Servo hardware pins (PCA9685 channels)
TEELA_PAN_PIN=0
TEELA_TILT_PIN=1

# Servo safe limits (degrees)
TEELA_PAN_MIN=-90.0
TEELA_PAN_MAX=90.0
TEELA_TILT_MIN=-45.0
TEELA_TILT_MAX=45.0

# CSI camera resolution
TEELA_CAM_WIDTH=1280
TEELA_CAM_HEIGHT=720
